diff --git a/src/authentication/authentication.window.js b/src/authentication/authentication.window.js
index 1da19f8..85cbde6 100644
--- a/src/authentication/authentication.window.js
+++ b/src/authentication/authentication.window.js
@@ -56,7 +56,11 @@ function createAuthenticationWindow({ partition } = {}) {
 	applyContextMenu(window)
 	applyZoom(window)
 
-	window.loadURL(getWindowUrl('authentication'))
+	// In the "add account" flow the window always has an isolated partition.
+	// Mark it with ?add=1 so the renderer knows not to pre-fill the server/user
+	// of an already logged-in account and lets the user enter a new server.
+	const url = getWindowUrl('authentication') + (partition ? '?add=1' : '')
+	window.loadURL(url)
 
 	return window
 }
